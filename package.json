{
  "name": "disciplines",
  "version": "0.10.1",
  "description": "Spec-first portable discipline profiles for agent skills and tools.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomcerdeira/disciplines.git"
  },
  "files": [
    "catalog",
    "disciplines",
    "dist",
    "docs",
    "examples",
    "schema",
    "src",
    "templates",
    "tsconfig.json",
    "README.md"
  ],
  "bin": {
    "disciplines": "dist/disciplines.js"
  },
  "types": "dist/lib/discipline-resolver.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/discipline-resolver.d.ts",
      "import": "./dist/lib/discipline-resolver.js"
    },
    "./resolver": {
      "types": "./dist/lib/discipline-resolver.d.ts",
      "import": "./dist/lib/discipline-resolver.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "resolve": "npm run build --silent && node dist/resolve-discipline.js",
    "validate": "npm run build --silent && node dist/validate-disciplines.js",
    "check:fixtures": "npm run build --silent && node dist/check-resolver-fixtures.js",
    "check:discovery": "npm run build --silent && node dist/check-discovery.js",
    "check:cli": "npm run build --silent && node dist/check-cli-workflows.js",
    "check:package": "npm run build --silent && node dist/check-package.js",
    "check:all": "npm run typecheck && npm run validate && npm run check:fixtures && npm run check:discovery && npm run check:cli && npm run check:package",
    "check:release": "npm run build --silent && node dist/check-release.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
